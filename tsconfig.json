{
	"extends": "astro/tsconfigs/strict",
	"compilerOptions": {
		"noUncheckedIndexedAccess": true,
		"exactOptionalPropertyTypes": true,
		"jsx": "react-jsx",
		"jsxImportSource": "react",
		"baseUrl": ".",
		"paths": {
			"@/*": [
				"src/*"
			]
		}
	},
	"include": [
		"src/**/*",
		"tests/**/*",
		"astro.config.mjs",
		"./worker-configuration.d.ts"
	],
	"exclude": [
		"dist",
		"node_modules",
		".astro"
	]
}