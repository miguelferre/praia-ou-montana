{
  "name": "praia-ou-montana",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Praia ou montaña — ¿playa o ruta hoy en Galicia? Recomendación según meteo, luz y distancia desde tu base.",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "typecheck": "astro check",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test --grep-invert @live",
    "check": "npm run typecheck && npm run lint && npm run format:check && npm run test"
  },
  "dependencies": {
    "@astrojs/react": "^4.2.0",
    "astro": "^5.5.0",
    "idb": "^8.0.0",
    "maplibre-gl": "^4.7.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "suncalc": "^1.9.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@axe-core/playwright": "^4.10.0",
    "@eslint/js": "^9.20.0",
    "@playwright/test": "^1.50.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/suncalc": "^1.9.2",
    "eslint": "^9.20.0",
    "eslint-plugin-astro": "^1.3.0",
    "eslint-plugin-jsx-a11y": "^6.10.0",
    "jsdom": "^26.0.0",
    "prettier": "^3.5.0",
    "prettier-plugin-astro": "^0.14.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.24.0",
    "vitest": "^3.0.0"
  }
}
